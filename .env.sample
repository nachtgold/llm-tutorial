# Copy to .env.local for `vercel dev`. In production these live in the Vercel
# project's Environment Variables. The app runs fine WITHOUT any of these — it
# just falls back to solo mode (no journey/admin), exactly like the old app
# without a database.

# --- Vercel Blob (source of truth: players, journey history) ---
# Auto-added to the project when you create a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# --- Vercel Edge Config (fast read projection of the active journey) ---
# EDGE_CONFIG is the read connection string, auto-added when you connect a store.
EDGE_CONFIG=
# Writes go through the Vercel REST API, which needs the store id + an API token
# (Account Settings → Tokens). Add the team slug if the project lives in a team.
EDGE_CONFIG_ID=
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# --- Admin login ---
# Generate a hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword',10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
# Optional: several admins as JSON instead of the single pair above:
# ADMINS=[{"username":"a","password_hash":"$2a$10$..."},{"username":"b","password_hash":"$2a$10$..."}]

# --- Admin session cookie signing (any long random string) ---
SESSION_SECRET=
